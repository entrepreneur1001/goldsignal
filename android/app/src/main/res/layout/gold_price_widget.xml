<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GoldSignal"
            android:textColor="@color/widget_text"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_currency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="USD"
            android:textColor="@color/widget_muted"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text=""
            android:textColor="@color/widget_muted"
            android:textSize="11sp" />

        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Refresh" />

        <ImageView
            android:id="@+id/widget_settings"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_marginStart="14dp"
            android:contentDescription="Settings" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:background="@color/widget_divider" />

    <!-- Gold row -->
    <LinearLayout
        android:id="@+id/gold_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/gold_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_icon_gold"
            android:contentDescription="Gold"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/gold_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gold"
                android:textColor="@color/widget_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/gold_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USD / gram"
                android:textColor="@color/widget_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/gold_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/widget_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/gold_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/widget_muted"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Silver row -->
    <LinearLayout
        android:id="@+id/silver_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/silver_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/widget_icon_silver"
            android:contentDescription="Silver"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/silver_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Silver"
                android:textColor="@color/widget_text"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/silver_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="USD / gram"
                android:textColor="@color/widget_muted"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/silver_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="@color/widget_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/silver_change"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/widget_muted"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
